# Fix de imágenes: si se pide /products/uploads/... redirige a /uploads/...
Options -MultiViews
RewriteEngine On
RewriteBase /products/

# 1. Quitar extensión .php (Redirección externa 301)
RewriteCond %{REQUEST_METHOD} ^(GET|HEAD)$ [NC]
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# 2. Añadir extensión .php internamente (Invisible)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/products/$1.php -f
RewriteRule ^(.+?)/?$ $1.php [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^uploads/(.+)$ /uploads/$1 [L,NC]
